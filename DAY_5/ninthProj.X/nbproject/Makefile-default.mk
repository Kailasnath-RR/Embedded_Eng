	${MP_CC_DIR}\\xc16-bin2hex ${DISTDIR}/ninthProj.X.${IMAGE_TYPE}.${DEBUGGABLE_SUFFIX} -a  -omf=elf   -mdfp="${DFP_DIR}/xc16" 
	
endif


